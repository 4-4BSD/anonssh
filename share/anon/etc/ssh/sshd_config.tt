Port 22
AllowUsers %%USER%%

PermitRootLogin no
PubkeyAuthentication no
PasswordAuthentication yes
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
PermitEmptyPasswords yes
DisableForwarding yes
X11Forwarding no
AllowTcpForwarding no
PermitUserRC no

LogLevel VERBOSE
UsePAM no

Match User %%USER%%
    ForceCommand %%BINARY%%
    PermitTTY yes
